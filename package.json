{
  "name": "hexedit",
  "version": "0.1.0beta",
  "scripts": {
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "copy": "node -e \"const fs=require('fs');const path=require('path');function cpDir(s,d){fs.mkdirSync(d,{recursive:true});for(const e of fs.readdirSync(s,{withFileTypes:true})){const sp=path.join(s,e.name),dp=path.join(d,e.name);e.isDirectory()?cpDir(sp,dp):fs.copyFileSync(sp,dp)}}cpDir('./views','./dist')\"",
    "dist": "npm run copy && npm run build",
    "dev": "webpack serve --mode development --open"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "babel-loader": "^9.2.0",
    "copy-webpack-plugin": "^12.0.0",
    "terser-webpack-plugin": "^5.3.0",
    "webpack": "^5.97.0",
    "webpack-cli": "^6.0.0",
    "webpack-dev-server": "^5.2.0"
  },
  "dependencies": {
    "angular": "^1.4.5",
    "angular-route": "^1.4.5",
    "angular-ui-bootstrap": "^0.13.4",
    "bootstrap": "^3.3.5",
    "clipboard": "^1.6.1",
    "file-saver": "^1.3.3",
    "hammerjs": "^2.0.8",
    "jailed": "^0.3.1",
    "jbinary": "^2.1.3",
    "jquery": "^2.1.4",
    "localforage": "^1.5.0"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
